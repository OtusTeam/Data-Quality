=== 1. Создание простых таблиц: ===

# Подключаемся к PostgreSQL и создаем простые таблицы
PGPASSWORD=airflow psql -h localhost -p 5432 -U airflow -d airflow << 'EOF'

-- 1. Справочник сущностей (минимальный)
DROP TABLE IF EXISTS d_entities CASCADE;
CREATE TABLE d_entities (
    entity_id INT PRIMARY KEY,
    entity_name VARCHAR(100) NOT NULL,
    entity_type VARCHAR(20) CHECK (entity_type IN ('store', 'online', 'warehouse')),
    country_code CHAR(2),
    is_active BOOLEAN DEFAULT TRUE,
    created_date DATE NOT NULL,
    updated_dttm TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 2. Таблица заказов (для проверок)
DROP TABLE IF EXISTS f_orders CASCADE;
CREATE TABLE f_orders (
    order_id SERIAL PRIMARY KEY,
    entity_id INT NOT NULL REFERENCES d_entities(entity_id),
    order_date DATE NOT NULL,
    order_value DECIMAL(10,2) NOT NULL,
    status VARCHAR(20) CHECK (status IN ('pending', 'completed', 'cancelled', 'returned')),
    customer_id INT,
    has_discount BOOLEAN DEFAULT FALSE,
    discount_percent DECIMAL(5,2) DEFAULT 0,
    created_dttm TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_dttm TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 3. Таблица закупок (для проверок свежести и референциальной целостности)
DROP TABLE IF EXISTS f_purchases CASCADE;
CREATE TABLE f_purchases (
    purchase_id SERIAL PRIMARY KEY,
    entity_id INT NOT NULL REFERENCES d_entities(entity_id),
    purchase_date DATE NOT NULL,
    supplier_id INT,
    total_amount DECIMAL(10,2) NOT NULL,
    items_count INT NOT NULL,
    is_paid BOOLEAN DEFAULT FALSE,
    created_dttm TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_dttm TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

EOF


