CREATE TABLE IF NOT EXISTS dq.dq_history (
    dq_check_id INTEGER NOT NULL,
    dq_dimension TEXT NOT NULL,
    value NUMERIC NOT NULL,
    target_value NUMERIC NOT NULL,
    metric_weight NUMERIC NOT NULL,
    dq_check_dttm TIMESTAMP WITH TIME ZONE NOT NULL,
    created_dttm TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE OR REPLACE VIEW dq.v_dq_1 AS

/* 1
Данные должны соблюдать иерархию согласно справочнику MSFO_PL_ITEMS_MAPPING. 
Для каждого отчетного периода, завода и бизнес-сценария должно выполняться правило: показатель на родительском WBS-элементе = сумме показателей дочерних WBS-элементов. 
Пример: VP-01-00-00 = VP-01-01-00 + VP-01-02-00
*/

WITH hierarchy AS 
( -- Получаем иерархию из справочника (только связи родитель-ребенок)
    SELECT wbs_element AS child_wbs
         , parental_wbs_element AS parent_wbs
      FROM b_pl_bm
     WHERE parental_wbs_element IS NOT NULL  -- только элементы, у которых есть родитель
),


child_values AS 
( -- Собираем все дочерние значения для каждого родителя в каждом контексте
    SELECT f.scenario
         , f.date
         , f.plant
         , h.parent_wbs AS parent_wbs
         , SUM(CAST(f."rub" AS NUMERIC)) AS children_sum
      FROM f_msfo_pl f
      JOIN hierarchy h ON f."wbs_element" = h.child_wbs
  GROUP BY f."scenario", f."date", f."plant", h.parent_wbs
),


parent_values AS 
( -- Собираем родительские значения для тех же комбинаций
    SELECT f."scenario"
         , f."date"
         , f."plant"
         , f."wbs_element" AS parent_wbs 
         , CAST(f."rub" AS NUMERIC) AS parent_value
      FROM f_msfo_pl f
     WHERE EXISTS (SELECT 1 FROM hierarchy where f."wbs_element" = hierarchy.parent_wbs)
),


details AS
( -- Соединяем родительские и дочерние значения для сравнения
    SELECT COALESCE(p."scenario", c."scenario") AS "scenario"
         , COALESCE(p."date", c."date") AS "date"
         , COALESCE(p."plant", c."plant") AS "plant"
         , COALESCE(p.parent_wbs, c.parent_wbs) AS "wbs_element"
         , p.parent_value AS "parent_value"
         , c.children_sum AS "children_sum"
         , COALESCE(p.parent_value, 0) - COALESCE(c.children_sum, 0) AS "difference"
      FROM parent_values p
 FULL JOIN child_values c ON p."scenario" = c."scenario" 
                         AND p."date" = c."date" 
                         AND p."plant" = c."plant" 
                         AND p.parent_wbs = c.parent_wbs
)
--проверяем, есть ли строки с ненулевой разницей
    SELECT 1 AS dq_check_id
         , 'Согласованность' AS dq_dimension
         , CASE WHEN (SELECT COUNT(*) FROM details WHERE difference > 1)=0 THEN 1 ELSE 0 END AS value
         , 1 AS target_value
         , 0.25 AS metric_weight
         , CURRENT_TIMESTAMP AS dq_check_dttm;

