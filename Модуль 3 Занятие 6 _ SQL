CREATE OR REPLACE VIEW dq.v_dq_2 AS
/* 2
По трем ключевым сценариям (ОП, БП, Факт) в рамках существующих комбинаций завода и периода должны присутствовать значения по WBS-элементам VP,VL,NP-00-00-00.
*/

WITH details AS
(
    SELECT DISTINCT s."scenario"
         , w."wbs_element"
         , d."date"
         , d."plant"
      FROM 
          (
           VALUES ('ОП'), ('БП'), ('Факт')
          )s(scenario)
CROSS JOIN 
          (
           VALUES ('VL-00-00-00'), ('VP-00-00-00'), ('NP-00-00-00')
          )w(wbs_element)
CROSS JOIN
          (
           SELECT DISTINCT "date", "plant"
             FROM f_msfo_pl
            WHERE "scenario" IN ('Факт', 'БП', 'ОП')
          )d
     WHERE NOT EXISTS (
                  		SELECT 1 
                  		  FROM f_msfo_pl f
                  		 WHERE f."scenario" = s."scenario"
                    		   AND f."date" = d."date"
                    		   AND f."plant" = d."plant"
                    		   AND f."wbs_element" = w."wbs_element"
                      )
)

    SELECT 2 AS dq_check_id
         , 'Полнота' AS dq_dimension
         , CASE WHEN (SELECT COUNT(*) FROM details)=0 THEN 1 ELSE 0 END AS value
         , 1 AS target_value
         , 0.1 AS metric_weight
         , CURRENT_TIMESTAMP AS dq_check_dttm;

