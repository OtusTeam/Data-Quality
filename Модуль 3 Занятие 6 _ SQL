CREATE OR REPLACE VIEW dq.v_dq_10 AS
/* 10

Значение фактических складских затрат в рамках периода и завода не должно отклоняться от среднемесячных фактических складских затрат за прошлый год более, чем на 15%. 
Значение за предыдущий год равняется 14000.
*/

WITH details AS
(
    SELECT date
         , plant
         , CASE WHEN CAST(rub AS NUMERIC) NOT BETWEEN 14000*0.85 AND 14000*1.15
                THEN 0.00 
                ELSE 1.00 
                 END AS value
      FROM f_msfo_pl pl
     WHERE wbs_element = 'VP-00-00-00'
       AND scenario = 'Факт'
)
    SELECT 10 AS dq_check_id
         , 'Согласованность' AS dq_dimension
         , AVG(value) AS value
         , 1 AS target_value
         , 0.1 AS metric_weight
         , CURRENT_TIMESTAMP AS dq_check_dttm
      FROM details;

