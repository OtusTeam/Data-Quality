CREATE OR REPLACE VIEW dq.v_dq_8 AS
/* 8 
Статья не может быть родителем самой себя
*/
    SELECT 8 AS dq_check_id
         , 'Согласованность' AS dq_dimension
         , CASE WHEN EXISTS (SELECT 1 FROM b_pl_bm WHERE wbs_element = parental_wbs_element) THEN 0 ELSE 1 END AS value
         , 1 AS target_value
         , 0.0375 AS metric_weight
         , CURRENT_TIMESTAMP AS dq_check_dttm;

