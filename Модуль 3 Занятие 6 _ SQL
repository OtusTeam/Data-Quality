CREATE OR REPLACE VIEW dq.v_dq_6 AS
/* 6
Проверка формата и структуры статей: должны соответствовать маске XX-NN-NN-NN, где X - буквы, N - цифры
*/

    SELECT 6 AS dq_check_id
         , 'Соответствие' AS dq_dimension
         , AVG(CASE WHEN wbs_element IS NOT NULL AND wbs_element ~ '^[A-Z]{2}-\d{2}-\d{2}-\d{2}$' THEN 1.00 ELSE 0 END) AS value
         , 1 AS target_value
         , 0.0375 AS metric_weight
         , CURRENT_TIMESTAMP AS dq_check_dttm
      FROM f_msfo_pl;


