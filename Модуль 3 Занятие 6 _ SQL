CREATE OR REPLACE VIEW dq.v_dq_7 AS
/* 7
Существование статьи: код статьи есть в справочнике MSFO_PL_ITEMS_MAPPING (b_pl_bm)
*/
    SELECT 7 AS dq_check_id
         , 'Целостность' AS dq_dimension
         , CASE WHEN (SELECT COUNT(*) FROM f_msfo_pl f WHERE NOT EXISTS (SELECT 1 FROM b_pl_bm b WHERE f.wbs_element = b.wbs_element))=0
                THEN 1
                ELSE 0
                 END AS value
         , 1 AS target_value
         , 0.0375 AS metric_weight
         , CURRENT_TIMESTAMP AS dq_check_dttm;


