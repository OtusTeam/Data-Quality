CREATE OR REPLACE VIEW dq.v_dq_3 AS
/* 3
Данные по сценарию Факт за отчетный месяц М-1 должны быть доступны не позднее 8 календарного дня месяца М, следующего за отчетным. 
Данные по ОП за отчетный месяц М должны быть доступны потребителю не позднее 1 календарного дня отчетного месяца М. 
*/

SELECT 3 AS dq_check_id
     , 'Своевременность' AS dq_dimension
     , CASE WHEN EXTRACT(DAY FROM current_date) = 8 
            THEN
                 CASE WHEN EXISTS 
                                 (
                                  SELECT 1 
                                    FROM f_msfo_pl 
                                   WHERE "scenario" = 'Факт' 
                                     AND "date"::date = date_trunc('month', current_date - interval '1' month)::date
                                 )
                      THEN 1 ELSE 0 END
         WHEN EXTRACT(DAY FROM current_date) = 1 
         THEN
                 CASE WHEN EXISTS 
                                 (
                                  SELECT 1 
                                    FROM f_msfo_pl 
                                   WHERE "scenario" = 'ОП' 
                                     AND "date"::date = date_trunc('month', current_date)::date
                                )
                      THEN 1 ELSE 0 END
         ELSE 1
         END AS value
     , 1 AS target_value
     , 0.1 AS metric_weight
     , CURRENT_TIMESTAMP AS dq_check_dttm;

