CREATE OR REPLACE VIEW dq.v_dq_5 AS
/* 5

В рамках отчетного периода, сценария и завода, максимальная величина расхождения между отчетом P&L и базой маржинальности не должно превышать 1%. 
Проверка выполняется только по статьям, указанным в маппинге. 
Статье VP-00-00-00 в P&L соответствует статья "Складские затраты" в БМ, VL-00-00-00 - "Объем производства", NP-00-00-00 - "Выручка"
*/

WITH pl AS
(
    SELECT pl."scenario"
         , pl."date"
         , pl."plant"
         , pl.wbs_element
         , CAST(pl.rub AS NUMERIC) rub
      FROM f_msfo_pl pl
      JOIN b_pl_bm mapping ON pl.wbs_element = mapping.wbs_element
),

mb AS
(
    SELECT f_bm."scenario"
         , f_bm."date"
         , f_bm."plant"
         , mapping."wbs_element"
         , CAST(f_bm."rub" AS NUMERIC) rub
      FROM f_bm
      JOIN b_pl_bm mapping ON f_bm."showing" = mapping."marginality_base_showing"
),

details AS
(
    SELECT COALESCE(pl.scenario, mb.scenario) scenario
         , COALESCE(pl.date, mb.date) date
         , COALESCE(pl.plant, mb.plant) plant
         , COALESCE(pl.wbs_element, mb.wbs_element) wbs_element
         , COALESCE(pl.rub, 0) pl
         , COALESCE(mb.rub, 0) mb
         , ABS(COALESCE(pl.rub,0) - COALESCE(mb.rub,0)) discrepancy
         , CASE WHEN 100 * ABS(COALESCE(pl.rub,0) - COALESCE(mb.rub,0)) / NULLIF(GREATEST(ABS(COALESCE(pl.rub,0)), ABS(COALESCE(mb.rub,0))), 0) > 1 
                THEN 0.00 
                ELSE 1.00 
                 END is_valid
      FROM pl
 FULL JOIN mb ON pl.scenario = mb.scenario
             AND pl.date = mb.date
             AND pl.plant = mb.plant
             AND pl.wbs_element = mb.wbs_element
)

    SELECT 5 AS dq_check_id
         , 'Согласованность' AS dq_dimension
         , AVG(is_valid) AS value
         , 1 AS target_value
         , 0.25 AS metric_weight
         , CURRENT_TIMESTAMP AS dq_check_dttm
      FROM details;


