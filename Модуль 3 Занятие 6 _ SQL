CREATE OR REPLACE VIEW dq.v_dq_4 AS
/* 4
В отчете не могут присутствовать данные по другим заводам
*/

SELECT 4 AS dq_check_id
     , 'Валидность' AS dq_dimension
     , CASE WHEN EXISTS (SELECT 1 FROM f_msfo_pl WHERE "plant" IS DISTINCT FROM 'RU01') THEN 0 ELSE 1 END AS value
     , 1 AS target_value
     , 0.05 AS metric_weight
     , CURRENT_TIMESTAMP AS dq_check_dttm;


