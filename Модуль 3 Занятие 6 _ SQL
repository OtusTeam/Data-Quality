CREATE OR REPLACE VIEW dq.v_dq_9 AS
/* 9
Нет двух строк с двумя уникальными комбинациями завод + период + статья + сценарий
*/

WITH duplicates_ AS
(
    SELECT plant
         , date
         , scenario
         , wbs_element
      FROM f_msfo_pl pl
  GROUP BY plant
         , date
         , scenario
         , wbs_element
    HAVING COUNT(*) > 1
)
    SELECT 9 AS dq_check_id
         , 'Уникальность' AS dq_dimension
         , CASE WHEN EXISTS (SELECT 1 FROM duplicates_) 
                THEN 0 
                ELSE 1 
                 END AS value
         , 1 AS target_value
         , 0.03 AS metric_weight
         , CURRENT_TIMESTAMP AS dq_check_dttm;


